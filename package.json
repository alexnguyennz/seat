		"@sveltejs/kit": "^1.22.1",
		"@tabler/icons-svelte": "^2.23.0",
		"atropos": "^2.0.2",
		"cloudinary": "^1.34.0",
		"flowbite": "^1.7.0",
		"flowbite-svelte": "^0.39.2",
		"svelte": "^3.54.0",
		"svelte-check": "^3.4.5",
		"swiper": "^8.4.5",
		"vite": "^4.4.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.28.1",
		"autoprefixer": "^10.4.13",
		"classnames": "^2.3.2",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
